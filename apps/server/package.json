{
  "name": "@pulsarbot/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node22 --out-dir dist",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^8.1.1",
    "@pulsarbot/agent": "workspace:*",
    "@pulsarbot/cloudflare": "workspace:*",
    "@pulsarbot/core": "workspace:*",
    "@pulsarbot/market": "workspace:*",
    "@pulsarbot/mcp": "workspace:*",
    "@pulsarbot/memory": "workspace:*",
    "@pulsarbot/providers": "workspace:*",
    "@pulsarbot/shared": "workspace:*",
    "@pulsarbot/storage": "workspace:*",
    "@pulsarbot/telegram": "workspace:*",
    "fastify": "^5.2.1",
    "grammy": "^1.35.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^2.4.5"
  }
}
